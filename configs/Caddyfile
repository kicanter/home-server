# Personal site
{$SITE_DOMAIN} {
    root * /srv/www/{$SITE_DOMAIN}/src
    handle {
        file_server
    }

    @publicFile file {
        root /srv/www/{$SITE_DOMAIN}/public
    }
    handle @publicFile {
        root * /srv/www/{$SITE_DOMAIN}/public
        file_server
    }

    handle_errors {
        @404 expression {err.status_code} == 404
        handle @404 {
            root * /srv/www/{$SITE_DOMAIN}/src
            rewrite * /404.html
            file_server
        }
    }
}

# Forgejo instance
{$FORGEJO_DOMAIN} {
    reverse_proxy forgejo:3000
}
