# Personal site
{$SITE_DOMAIN} {
    root * /srv/www/{$SITE_DOMAIN}/src
    @publicFile file {
        root /srv/www/{$SITE_DOMAIN}/public
    }
    handle @publicFile {
        root * /srv/www/{$SITE_DOMAIN}/public
        file_server
    }
    handle {
        file_server
    }
}

# Forgejo instance
{$FORGEJO_DOMAIN} {
    reverse_proxy forgejo:3000
}
